# Sanity CMS
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01
SANITY_API_READ_TOKEN=

# Email (contact / appointment forms)
RESEND_API_KEY=
CONTACT_FORM_TO_EMAIL=

# Analytics
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Google Reviews (server-only — never exposed to the browser)
# Needs the Places API enabled on this key in Google Cloud Console.
GOOGLE_PLACES_API_KEY=
# Optional: skip the Find Place lookup by pinning the exact place_id.
GOOGLE_PLACE_ID=

# Site
NEXT_PUBLIC_SITE_URL=http://localhost:3000
